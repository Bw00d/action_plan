<%= content_for :title, "203" %>
<%
  # Compute how many empty pad rows to render at the bottom of each column
  # so both columns end at the same y. Each section takes
  # 1 header + max(min, count) data + 1 blank-add row. Column target is the
  # taller of the two columns' natural row count, floored at 42 (the row
  # capacity of a Letter page at 22px so PDFs fill cleanly).
  cmd_rows = 1 + [6,  @plan.command_staff.count].max + 1
  agy_rows = 1 + [6,  @plan.agency_reps.count  ].max + 1
  pln_rows = 1 + [8,  @plan.plans.count        ].max + 1
  log_rows = 1 + [6,  @plan.logistics.count    ].max + 1
  ops_rows = 1 + [20, @plan.operations.count   ].max + 1
  fin_rows = 1 + [3,  @plan.finance.count      ].max + 1

  left_used   = 2 + cmd_rows + agy_rows + pln_rows + log_rows
  right_used  = 2 + ops_rows + fin_rows
  column_target = [left_used, right_used, 42].max
  @left_pad_rows  = column_target - left_used
  @right_pad_rows = column_target - right_used
%>
<div id="organization-assignments">
  <div class="container">
    <div class="col-xs-12 col-lg-8 center-block">


      <div class="row">
        <div class="plan-panel-head">
          <ul class="tabrow">
            <li><%= link_to 'Plan', incident_plan_path(@incident, @plan) %></li>
            <li><%= link_to "Cover", incident_plan_covers_path(@incident, @plan)  %></li>
            <li><%= link_to "202", "../#{@plan.id}/202" %></li>
            <li class="selected"><%= link_to "203", "../#{@plan.id}/203" %></li>
            <li><%= link_to "204", incident_plan_assignments_path(@incident, @plan) %></li>
            <li><%= link_to "205", incident_plan_commo_plans_path(@incident, @plan) %></li>
            <li><%= link_to "206", '#' %></li>
            <li><%= link_to "220", '#' %></li>
            <li><%= link_to "Safety Message", incident_plan_safety_messages_path(@incident, @plan) %></li>
          </ul>
          </div>
        <div class="masking-tape"></div>
      </div>
  


      <div class="row org-columns">
        <div class="left-column col-xs-6"> <!-- Left Column-->
          <div class="row">
            <div id='title-box'class="col-xs-12 content-box top-row">
              <h4><strong>ORGANIZATION ASSIGNMENT LIST</strong></h4>
            </div>
          </div>
          <div class="row">
            <div class="col-xs-12 content-box ">
          <span class="small">INCIDENT NAME</span>
            <span class="lg-padding-left"><%= @incident.name %></span>
        </div>
          </div>
          <div class="row">
            <div class="col-xs-12 content-box header-row"> COMMAND AND GENERAL STAFF </div>
          </div>

          <!-- BEGIN Command Staff -->
          <% @plan.command_staff.each do |s| %>
            <%= render 'org_row', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                <span class="team-form">
                  <%= form_for @team do |f| %>
                    <%= f.hidden_field :staff, value: "Command" %>
                    <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%# resource_name and position deliberately not set —
                      the row starts nil and the _org_row.html.erb partial
                      renders "(POSITION)" / "(NAME)" as a place_holder
                      only, so the PDF prints blank cells. %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
              <span class="team-form">
                <%= form_for @team do |f| %>
                  <%= f.hidden_field :staff, value: "Command" %>
                  <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add blank position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
            </div>
              <div class="content-box col-xs-6"></div>
            </div>
          <% (6 - @plan.command_staff.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>              
            </div>
          <% end %>
          <!-- END Command Staff -->
          <!-- BEGIN Agency Admins -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">AGENCY REPRESENTATIVES</div>     <!-- Agency Reps-->        
          </div>
          <% @plan.agency_reps.each do |s| %>
            <%= render 'org_row', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                <span class="team-form">
                  <%= form_for @team do |f| %>
                    <%= f.hidden_field :staff, value: "Agency" %>
                    <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%# resource_name and position deliberately not set —
                      the row starts nil and the _org_row.html.erb partial
                      renders "(POSITION)" / "(NAME)" as a place_holder
                      only, so the PDF prints blank cells. %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
              <span class="team-form">
                <%= form_for @team do |f| %>
                  <%= f.hidden_field :staff, value: "Agency" %>
                  <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add blank position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
            </div>      
              <div class="content-box col-xs-6"></div>      
            </div>
          <% (6 - @plan.agency_reps.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>             
            </div>
          <% end %>
          <!-- END Agency Admins -->
          <!-- START Plans -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">PLANNING SECTION</div>     <!-- Planning Section-->        
          </div>
          <% @plan.plans.each do |s| %>
            <%= render 'org_row', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                <span class="team-form">
                  <%= form_for @team do |f| %>
                    <%= f.hidden_field :staff, value: "Plans" %>
                    <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%# resource_name and position deliberately not set —
                      the row starts nil and the _org_row.html.erb partial
                      renders "(POSITION)" / "(NAME)" as a place_holder
                      only, so the PDF prints blank cells. %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
              <span class="team-form">
                <%= form_for @team do |f| %>
                  <%= f.hidden_field :staff, value: "Plans" %>
                  <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add blank position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
            </div>
              <div class="content-box col-xs-6"></div>
            </div>
            <% (8 - @plan.plans.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>              
            </div>
          <% end %>
          <!-- END Plans -->
          <!-- START Logistics (left column) -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">LOGISTICS SECTION</div>
          </div>
            <% @plan.logistics.each do |s| %>
              <%= render 'org_row', team: s %>
            <% end %>
              <div class="row blank-row">
                <div class="content-box col-xs-6">
                  <span class="team-form">
                    <%= form_for @team do |f| %>
                      <%= f.hidden_field :staff, value: "Logistics" %>
                      <%= f.hidden_field :plan_id, value: @plan.id %>
                    <%# See partial for place_holder rendering; row starts nil. %>
                    <%= f.button type: :submit, class: "add-org-btn", title: "Add position" do %>
                      <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                    <% end %>
                  <% end %>
                </span>
                <span class="team-form">
                  <%= form_for @team do |f| %>
                    <%= f.hidden_field :staff, value: "Logistics" %>
                    <%= f.hidden_field :plan_id, value: @plan.id %>
                    <%= f.button type: :submit, class: "add-org-btn", title: "Add blank position" do %>
                      <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                    <% end %>
                  <% end %>
                </span>
              </div>
                <div class="content-box col-xs-6"></div>
              </div>
              <% (6 - @plan.logistics.count).times do %>
              <div class="row">
                <div class="content-box col-xs-6"></div>
                <div class="content-box col-xs-6"></div>
              </div>
            <% end %>
          <!-- END Logistics (left column) -->

          <%# Real DOM rows to pad the column down to the target height so
              its bottom lands at the same y as the right column's bottom.
              Real rows render crisp 1px borders (unlike the gradient
              approach, which anti-aliased into gray in the PDF). %>
          <% @left_pad_rows.times do %>
            <div class="row">
              <div class="col-xs-6 content-box"></div>
              <div class="col-xs-6 content-box"></div>
            </div>
          <% end %>

        </div> <!-- END LEFT COLUMN-->

        <div class="right-column col-xs-6"> <!-- START RIGHT COLUMN-->
          <div class="row">
            <div class="col-xs-12 content-box top-row">
              <span class="small">DATE </span>
              <span class="lg-padding-left"><%= @plan.date.try(:strftime,"%-m/%d/%y") %></span>
            </div>
          </div>
          <div class="row">
            <div class="col-xs-12 content-box">
               <span class="small">OPERATIONAL PERIOD</span>
               <span class="lg-padding-left">0800 - 2200</span>
            </div>
          </div>
          <!-- START Ops -->
          <div class="row">
            <div class="col-xs-12 content-box header-row"> OPERATIONS </div>
          </div>
          <% @plan.operations.each do |s| %>
            <%= render 'org_row', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                <span class="team-form">
                  <%= form_for @team do |f| %>
                    <%= f.hidden_field :staff, value: "Operations" %>
                    <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%# resource_name and position deliberately not set —
                      the row starts nil and the _org_row.html.erb partial
                      renders "(POSITION)" / "(NAME)" as a place_holder
                      only, so the PDF prints blank cells. %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
              <span class="team-form">
                <%= form_for @team do |f| %>
                  <%= f.hidden_field :staff, value: "Operations" %>
                  <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add blank position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
            </div>
              <div class="content-box col-xs-6">
                <span class="team-form">
                  <%= form_for @team do |f| %>
                    <%= f.hidden_field :staff, value: "Operations" %>
                    <%= f.hidden_field :plan_id, value: @plan.id %>
                    <%= f.hidden_field :header_label, value: "HEADER" %>
                  <%= f.button type: :submit, class: "add-org-btn add-header-btn", title: "Add header row" do %>
                    <%= fa_icon 'header' %>
                  <% end %>
                <% end %>
              </span>
              </div>
            </div>
            <% (20 - @plan.operations.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>       
            </div>
          <% end %>
          <!-- END Ops -->
          <!-- BEGIN Finance (right column) -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">FINANCE SECTION</div>
          </div>
          <% @plan.finance.each do |s| %>
            <%= render 'org_row', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                <span class="team-form">
                  <%= form_for @team do |f| %>
                    <%= f.hidden_field :staff, value: "Finance" %>
                    <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%# resource_name and position deliberately not set —
                      the row starts nil and the _org_row.html.erb partial
                      renders "(POSITION)" / "(NAME)" as a place_holder
                      only, so the PDF prints blank cells. %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
              <span class="team-form">
                <%= form_for @team do |f| %>
                  <%= f.hidden_field :staff, value: "Finance" %>
                  <%= f.hidden_field :plan_id, value: @plan.id %>
                  <%= f.button type: :submit, class: "add-org-btn", title: "Add blank position" do %>
                    <%= image_tag 'user-plus.svg', class: 'add-org-icon' %>
                  <% end %>
                <% end %>
              </span>
            </div>
              <div class="content-box col-xs-6"></div>
            </div>
            <% (3 - @plan.finance.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>
              <div class="content-box col-xs-6"></div>
            </div>
          <% end %>
          <!-- END Finance (right column) -->

          <%# Real DOM rows to pad the column down to the target height. %>
          <% @right_pad_rows.times do %>
            <div class="row">
              <div class="col-xs-6 content-box"></div>
              <div class="col-xs-6 content-box"></div>
            </div>
          <% end %>

        </div> <!-- END RIGHT COLUMN -->
      </div> 
        <div class="row bottom-row">
          <div class="content-box col-xs-6">Prepared by:</div>
          <div class="content-box col-xs-6">Approved by:</div>
        </div>

    <div class="print-button"><%= link_to "PRINT", "../#{@plan.id}/203-pdf.pdf", class: "btn btn-success tiny", target: :_blank %></div>
    </div>
  </div>
</div>