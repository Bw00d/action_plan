
<div id="incident-objectives">

    <div id="print-container">
      <%# Top row %>
      <div class="col-xs-12 title-row bl top-row fixed-height-row">
        <div class="col-xs-4">
          <h5><strong>INCIDENT OBJECTIVES</strong></h5>
        </div>
        <div class="col-xs-3 bl form-box">
          <span class="small">1. INCIDENT NAME<br>
            <span class="sm-padding-left"><%= @incident.name %></span>
          </span>
        </div>
        <div class="col-xs-2 bl form-box">
          <span class="small">2. DATE<br>
            <%= @plan.date.try(:strftime,"%-m/%d/%y") %>
          </span>
        </div>
        <div class="col-xs-3 bl form-box">
          <span class="small">3. OPERATIONAL PERIOD<br>
            <%=  @plan.ops_period %>
          </span>
        </div>
      </div>

      <%# Control Objectives row %>
      <div class="resizable-row" id="objectives-row">
        <div id="control-objectives-pdf" class="col-xs-12 row-content">
              <span class="small">4. GENERAL CONTROL OBJECTIVES FOR INCIDENT</span>
              <ul>
                <% @plan.objectives.each do |o| %>
                <li><%= o.description %></li>
                <% end %>
              </ul>
            </div>
          </div>
          <div class="resize-handle" data-target="objectives-row"></div>

      <%# Operations emphasis row %>
      <div class="resizable-row" id="emphasis-row">
      <div id="operational-emphasis-pdf" class="col-xs-12 row-content">
        <% if @incident.wildfire? %>
          <span class="small">5. OPERATIONAL PERIOD EMPHASIS</span><br>
        <% else %>
          <span class="small">5. GENERAL SITUATION AWARENESS</span><br>
        <% end %>
           <%=  simple_format(@plan.weather)  %>
      </div>
      </div>
      <div class="resize-handle" data-target="emphasis-row"></div>

      <%#  General Safety row %>
      <div class="resizable-row" id="safety-row">
      <div id="general-safety-message-pdf" class="col-xs-12 row-content">
        <span class="small">6. GENERAL SAFETY MESSAGE</span><br>
          <%=  simple_format(@plan.general_safety)  %>
      </div>
      </div>


      <%# Attachments row %>
      <div id="attachments" class="col-xs-12 fixed-height-row">
        <span class="small">7. ATTACHMENTS</span><br>
          <ul class="small col-xs-3">

            <% @first_attachments.each do |a| %>
              <li> 
                <%= a.attached ? "☑" : "☐" %>
                <%= a.description %>
              </li>
            <% end %>
          </ul>
          <ul class="small col-xs-3">
            <% @second_attachments.each do |a| %>
              <li>
                <%= a.attached ? "☑" : "☐" %>
                <%= a.description %>
              </li>
            <% end %>
          </ul>
          <ul class="small col-xs-3">
            <% @third_attachments.each do |a| %>
              <li>
                <%= a.attached ? "☑" : "☐" %>
                <%= a.description %>
              </li>
            <% end %>
          </ul>
          <ul class="small col-xs-3">
            <% @fourth_attachments.each do |a| %>
              <li>
                <%= a.attached ? "☑" : "☐" %>
                <%= a.description %>
              </li>
            <% end %>
          </ul>
      </div>
      <%# Prepared by row %>
      <div class="prepared-by-row col-xs-12 fixed-height-row">
        <div class="col-xs-6">
          <span class="small small-box">8. PREPARED BY</span><br>
          <span class="lg-padding-left"><%=  @plan.prepared_by %></span>
        </div>
        <div class="col-xs-6 bl">
          <span class="small small-box">9. APPROVED BY</span><br>
          <span class="lg-padding-left"><%=  @plan.approved_by %></span>
        </div>
      </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Apply heights from URL parameters
  const urlParams = new URLSearchParams(window.location.search);
  
  ['objectives-row', 'emphasis-row', 'safety-row'].forEach(rowId => {
    const height = urlParams.get(rowId);
    if (height) {
      const row = document.getElementById(rowId);
      if (row) {
        // Constrain height for PDF to fit on single page
        const constrainedHeight = Math.min(Math.max(50, parseInt(height)), 200);
        row.style.height = constrainedHeight + 'px';
      }
    }
  });
});
</script>

