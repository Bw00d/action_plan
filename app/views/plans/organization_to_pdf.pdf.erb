
<%
  # Same column-target math as the HTML view — see incident_organization.html.erb.
  cmd_rows = 1 + [6,  @plan.command_staff.count].max + 1
  agy_rows = 1 + [6,  @plan.agency_reps.count  ].max + 1
  pln_rows = 1 + [8,  @plan.plans.count        ].max + 1
  log_rows = 1 + [6,  @plan.logistics.count    ].max + 1
  ops_rows = 1 + [20, @plan.operations.count   ].max + 1
  fin_rows = 1 + [3,  @plan.finance.count      ].max + 1

  left_used   = 2 + cmd_rows + agy_rows + pln_rows + log_rows
  right_used  = 2 + ops_rows + fin_rows
  column_target = [left_used, right_used, 42].max
  @left_pad_rows  = column_target - left_used
  @right_pad_rows = column_target - right_used
%>
<div id="organization-assignments">
  <div class="container">
      
    <div class="col-xs-12 col-lg-8 center-block">

      <div class="row org-columns">
        <div class="left-column col-xs-6"> <!-- Left Column-->
          <div class="row">
            <div class="col-xs-12 content-box top-row">
              <h4 ><strong>ORGANIZATION ASSIGNMENT LIST</strong></h4>
            </div>
          </div>
          <div class="row">
            <div class="col-xs-12 content-box ">
          <span class="small">INCIDENT NAME</span>
            <span class="lg-padding-left"><%= @incident.name %></span>
        </div>
          </div>
          <div class="row">
            <div class="col-xs-12 content-box header-row"> COMMAND AND GENERAL STAFF </div>
          </div>

          <!-- BEGIN Command Staff -->
          <% @plan.command_staff.each do |s| %>
            <%= render 'org_row_pdf', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                
            </div>      
              <div class="content-box col-xs-6"></div>      
            </div>
          <% (6 - @plan.command_staff.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>             
            </div>
          <% end %>
          <!-- END Command Staff -->
          <!-- BEGIN Agency Admins -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">AGENCY REPRESENTATIVES</div>     <!-- Agency Reps-->        
          </div>
          <% @plan.agency_reps.each do |s| %>
            <%= render 'org_row_pdf', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                
            </div>      
              <div class="content-box col-xs-6"></div>      
            </div>
          <% (6 - @plan.agency_reps.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>              
            </div>
          <% end %>
          <!-- END Agency Admins -->
          <!-- START Plans -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">PLANNING SECTION</div>     <!-- Planning Section-->        
          </div>
          <% @plan.plans.each do |s| %>
            <%= render 'org_row_pdf', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                
            </div>      
              <div class="content-box col-xs-6"></div>      
            </div>
            <% (8 - @plan.plans.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>             
            </div>
          <% end %>
          <!-- END Plans -->
          <!-- START Logistics (left column) -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">LOGISTICS SECTION</div>
          </div>
            <% @plan.logistics.each do |s| %>
              <%= render 'org_row_pdf', team: s %>
            <% end %>
              <div class="row blank-row">
                <div class="content-box col-xs-6">

              </div>
                <div class="content-box col-xs-6"></div>
              </div>
              <% (6 - @plan.logistics.count).times do %>
              <div class="row">
                <div class="content-box col-xs-6"></div>
                <div class="content-box col-xs-6"></div>
              </div>
            <% end %>
          <!-- END Logistics (left column) -->

          <% @left_pad_rows.times do %>
            <div class="row">
              <div class="col-xs-6 content-box"></div>
              <div class="col-xs-6 content-box"></div>
            </div>
          <% end %>

        </div> <!-- END LEFT COLUMN-->

        <div class="right-column col-xs-6"> <!-- START RIGHT COLUMN-->
          <div class="row">
            <div class="col-xs-12 content-box top-row">
              <span class="small">DATE </span>
              <span class="lg-padding-left"><%= @plan.date.try(:strftime,"%-m/%d/%y") %></span>
            </div>
          </div>
          <div class="row">
            <div class="col-xs-12 content-box">
               <span class="small">OPERATIONAL PERIOD</span>
               <span class="lg-padding-left">0800 - 2200</span>
            </div>
          </div>
          <!-- START Ops -->
          <div class="row">
            <div class="col-xs-12 content-box header-row"> OPERATIONS </div>
          </div>
          <% @plan.operations.each do |s| %>
            <%= render 'org_row_pdf', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
                
            </div>      
              <div class="content-box col-xs-6"></div>      
            </div>
            <% (20 - @plan.operations.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>      
              <div class="content-box col-xs-6"></div>       
            </div>
          <% end %>
          <!-- END Ops -->
          <!-- BEGIN Finance (right column) -->
          <div class="row">
            <div class="content-box col-xs-12 header-row">FINANCE SECTION</div>
          </div>
          <% @plan.finance.each do |s| %>
            <%= render 'org_row_pdf', team: s %>
          <% end %>
            <div class="row blank-row">
              <div class="content-box col-xs-6">
            </div>
              <div class="content-box col-xs-6"></div>
            </div>
            <% (3 - @plan.finance.count).times do %>
            <div class="row">
              <div class="content-box col-xs-6"></div>
              <div class="content-box col-xs-6"></div>
            </div>
          <% end %>
          <!-- END Finance (right column) -->

          <% @right_pad_rows.times do %>
            <div class="row">
              <div class="col-xs-6 content-box"></div>
              <div class="col-xs-6 content-box"></div>
            </div>
          <% end %>

        </div> <!-- END RIGHT COLUMN -->
      </div> 
        <div class="row bottom-row">
          <div class="content-box col-xs-6">Prepared by:</div>
          <div class="content-box col-xs-6">Approved by:</div>
        </div>

    </div>
  </div>
</div>
<script type="text/javascript">
    $(document).on("turbolinks:load", function() {
      $('#header').hide();
      $('.footer').hide();
      $('.header-row').css('background-color', "#f3f3f3");
      $('body').css("padding-top", 25);
      $('body').css("padding-right", 10);
      $('body').css("padding-left", 10);
    });
  </script>