<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <style>
      /* PDF-specific overrides and essential styles */
      @page {
        size: letter;
        margin: -50px 10px 10px 10px !important;
      }
      
      
      /* Hide elements that shouldn't appear in PDFs */
      .no-print, 
      .resources-button,
      .header-button,
      .new-freq-button,
      #header, 
      nav, 
      .footer {
        display: none !important;
      }
      
      /* Ensure print background colors */
      @media print {
        <%# body {
          print-color-adjust: exact;
          -webkit-print-color-adjust: exact;
        } %>
      }

    </style>
  </head>
  <body>
    <div class="page-wrapper">
      <%= yield %>
    </div>
  </body>
</html>