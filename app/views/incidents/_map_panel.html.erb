<%# Incident map. Prefers a WFIGS perimeter polygon when available; falls
    back to a marker at the incident's lat/long if not. %>

<link rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""/>

<div class="panel panel-default incident-map-panel">
  <div class="panel-heading">
    <h4><strong>Incident Map</strong>
      <small class="pull-right" id="perimeter-status">Loading…</small>
    </h4>
  </div>
  <div id="incident-map"
       data-perimeter-url="<%= incident_perimeter_path(@incident) %>"
       data-lat="<%= @incident.latitude %>"
       data-lng="<%= @incident.longitude %>"
       data-incident-type="<%= @incident.incident_type %>"
       data-incident-name="<%= @incident.name %>"
       data-incident-location="<%= @incident.location %>"
       style="height: 420px; width: 100%; background: #eef2f5;">
  </div>
  <div class="panel-body" id="perimeter-info" style="display:none;">
    <div class="row">
      <div class="col-sm-3"><strong>Start Date:</strong> <span id="perimeter-start-date">—</span></div>
      <div class="col-sm-3"><strong>Size:</strong> <span id="perimeter-acres">—</span></div>
      <div class="col-sm-3"><strong>Containment:</strong> <span id="perimeter-contained">—</span></div>
      <div class="col-sm-3"><strong>Cause:</strong> <span id="perimeter-cause">—</span></div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>

<script>
(function () {
  var mapEl = document.getElementById('incident-map');
  if (!mapEl || typeof L === 'undefined') return;

  var status = document.getElementById('perimeter-status');
  var info   = document.getElementById('perimeter-info');
  var url    = mapEl.dataset.perimeterUrl;

  var lat = parseFloat(mapEl.dataset.lat);
  var lng = parseFloat(mapEl.dataset.lng);
  var hasLatLng = !isNaN(lat) && !isNaN(lng);
  var incidentType     = (mapEl.dataset.incidentType || '').toLowerCase();
  var incidentName     = mapEl.dataset.incidentName || 'Incident';
  var incidentLocation = mapEl.dataset.incidentLocation || '';

  // Font Awesome (v4) icon per incident type, styled to look like a pin.
  // Keys must be lowercase — the lookup lowercases incident_type first.
  var TYPE_ICONS = {
    'wildfire': { icon: 'fire',                 color: '#d32f2f' },  // red
    'fire':     { icon: 'fire',                 color: '#d32f2f' },  // red
    'hazmat':   { icon: 'flask',                color: '#7b1fa2' },  // toxic purple
    'flood':    { icon: 'tint',                 color: '#1976d2' },  // blue
    'spill':    { icon: 'flask',                color: '#5d4037' },  // oil brown
    'slide':    { icon: 'exclamation-triangle', color: '#795548' },  // earth brown
    'shooting': { icon: 'crosshairs',           color: '#b71c1c' },  // dark red
    'epidemic': { icon: 'heartbeat',            color: '#c2185b' },  // biohazard magenta
    'event':    { icon: 'calendar',             color: '#1565c0' },  // civic blue
    'other':    { icon: 'map-marker',           color: '#616161' }   // neutral grey (fallback)
  };

  function iconForType(t) {
    var cfg = TYPE_ICONS[t] || TYPE_ICONS['other'];
    return L.divIcon({
      html: '<span class="incident-origin-pin" style="color:' + cfg.color + '">' +
              '<i class="fa fa-' + cfg.icon + '"></i>' +
            '</span>',
      className: 'incident-origin-marker',
      iconSize:   [40, 48],
      iconAnchor: [20, 44],
      popupAnchor:[0, -40]
    });
  }

  // Sensible default view: continental US. If nothing to show, this is what
  // the user sees.
  var map = L.map('incident-map').setView([39.5, -98.0], 4);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 18,
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>'
  }).addTo(map);

  // Drop the origin marker at the incident lat/long. Only used as a fallback
  // when there's no WFIGS perimeter available — if the perimeter renders,
  // the marker is deliberately omitted since the polygon already conveys
  // where the fire is.
  function dropOriginMarker() {
    if (!hasLatLng) return false;
    var marker = L.marker([lat, lng], { icon: iconForType(incidentType) }).addTo(map);
    var popupHtml = '<strong>' + incidentName + '</strong>';
    if (incidentLocation) popupHtml += '<br>' + incidentLocation;
    marker.bindPopup(popupHtml);
    return true;
  }

  fetch(url, { headers: { 'Accept': 'application/geo+json' } })
    .then(function (r) { return r.json(); })
    .then(function (geo) {
      if (!geo || !geo.features || geo.features.length === 0) {
        // No perimeter — fall back to the origin marker.
        if (dropOriginMarker()) {
          map.setView([lat, lng], 10);
          status.textContent = 'No perimeter available · showing origin';
        } else {
          status.textContent = 'No location data available';
        }
        return;
      }
      // Perimeter path. Draw the polygon and fit the map to it. No marker —
      // the polygon itself is the visual, and stacking a pin on top adds
      // clutter without new information.
      var layer = L.geoJSON(geo, {
        style: { color: '#c62828', weight: 2, fillColor: '#ef5350', fillOpacity: 0.25 }
      }).addTo(map);
      map.fitBounds(layer.getBounds(), { padding: [16, 16] });

      var props = geo.features[0].properties || {};

      var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      function formatDate(ms) {
        if (!ms) return '—';
        var d = new Date(ms);
        return MONTHS[d.getUTCMonth()] + ' ' + d.getUTCDate() + ', ' + d.getUTCFullYear();
      }
      function formatAcres(n) {
        if (n === null || n === undefined) return '—';
        return Math.round(n).toLocaleString('en-US') + ' ac';
      }
      function formatPercent(n) {
        if (n === null || n === undefined) return '—';
        return Math.round(n) + '%';
      }

      var acres = props.attr_IncidentSize
               || props.attr_CalculatedAcres
               || props.attr_FinalAcres;

      document.getElementById('perimeter-start-date').textContent = formatDate(props.attr_FireDiscoveryDateTime);
      document.getElementById('perimeter-acres').textContent      = formatAcres(acres);
      document.getElementById('perimeter-contained').textContent  = formatPercent(props.attr_PercentContained);
      document.getElementById('perimeter-cause').textContent      = props.attr_FireCause || '—';

      info.style.display = 'block';
      status.textContent = geo.features.length + ' feature' + (geo.features.length === 1 ? '' : 's');
    })
    .catch(function (err) {
      console.error('perimeter fetch failed', err);
      // Fetch failed — try the marker as a fallback.
      if (dropOriginMarker()) {
        map.setView([lat, lng], 10);
        status.textContent = 'Perimeter unavailable · showing origin';
      } else {
        status.textContent = 'Map unavailable';
      }
    });
})();
</script>
