<%= form_for [@incident, @plan, @assignment] do |form| %>
  <% if assignment.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(assignment.errors.count, "error") %> prohibited this assignment from being saved:</h2>

      <ul>
      <% assignment.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :org_unit_id, 'Division / Group' %>
    <% selectable_units = @incident.org_units.where(kind: [OrgUnit.kinds[:division], OrgUnit.kinds[:group]]).order(:name) %>
    <%= form.select :org_unit_id,
                    selectable_units.map { |u| ["#{u.name} (#{u.kind.capitalize})", u.id] },
                    { include_blank: '— pick one —' },
                    class: 'form-control' %>
    <small class="text-muted">Resources for this 204 come from whatever's on the board for the selected unit.</small>
  </div>

  <div class="form-group">
    <%= form.label :designator %>
    <%= form.text_field :designator, id: :assignment_designator, class: "form-control" %>
    <small class="text-muted">Optional override. Defaults to the org unit's designator if left blank.</small>
  </div>
  <div class="form-group">
    <%= form.label :control_operations %>
    <%= form.text_area :control_operations, id: :assignment_control_operations, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :special_instructions %>
    <%= form.text_area :special_instructions, id: :assignment_special_instructions, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.hidden_field :plan_id, id: :assignment_plan_id, value: @plan.id %>
  </div>

  <div class="actions">
    <%= form.submit "ADD 204", class: "btn btn-success" %>
  </div>
<% end %>
