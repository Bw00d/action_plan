<%= content_for :title, "Resources"  %>
<p id="notice"><%= notice %></p>
<div class="incident-name">
  <h1><%= link_to @incident.display_incident_name, @incident %></h1>
</div>

<!-- plans tabs -->
    <div class="resources-panel-head">
      <ul class="tabrow resource-tabs">
          <li  class="resource-tab selected">
              <%= link_to 'ICS-211', "javascript:;", class: "resource-tab-link", id: "ics-211-tab"%>
          </li>
          <li class="resource-tab">
              <%= link_to 'Glide Path', "javascript:;", class: "resource-tab-link", id: "glide-tab" %>
          </li>
          <li class="resource-tab">
              <%= link_to 'Demob List', "javascript:;", class: "resource-tab-link", id: "demob-tab" %>
          </li>
          <li class="resource-tab">
              <%= link_to 'Resource Tally', "javascript:;", class: "resource-tab-link", id: "tally-tab" %>
          </li>
          
        <%= link_to "javascript:;" do %>
          <%= image_tag 'user-plus.svg', class: "float-right", id: 'new-resource' %>
        <% end %>

        <%#= link_to new_incident_dump_import_path(@incident),
                    class: "float-right import-dump",
                    id: "import-dump",
                    title: "Import IROC dump" do %>
          <%#= fa_icon 'cloud-upload' %>
        <%# end %>
        </ul>
      </div>
    <div class="masking-tape"></div>
        
    <!-- end plans tabs -->
    <%= render 'ics_211' %>
    <%= render 'glide' %>
    <%= render 'demob' %>
    <%= render 'tally' %>
