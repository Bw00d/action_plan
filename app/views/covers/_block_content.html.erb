<%# Canvas block. x/y are the CENTER of the block as a percentage of
    the canvas dimensions. Convert to top-left for CSS positioning so
    jQuery UI's containment/pixel math stays intuitive. Font size is
    resolved to an absolute pixel value here — a preset ("h1".."h4")
    maps to a size, otherwise the string is parsed as a pixel number. %>
<% left_pct = block.x.to_f - block.width.to_f  / 2.0 %>
<% top_pct  = block.y.to_f - block.height.to_f / 2.0 %>
<%
  preset_px = { "h1" => 48, "h2" => 32, "h3" => 24, "h4" => 18 }
  font_px   = preset_px[block.font_size] || block.font_size.to_i
  font_px   = 24 if font_px <= 0
%>
<div id="<%= dom_id(block) %>"
     class="cover-block <%= 'is-image' if block.image_block? %> <%= block.font_size %> weight-<%= block.font_weight %> style-<%= block.text_style %> align-<%= block.text_align %>"
     data-block-id="<%= block.id %>"
     data-font-size="<%= block.font_size %>"
     style="left: <%= left_pct %>%; top: <%= top_pct %>%; width: <%= block.width %>%; height: <%= block.height %>%; <%= "font-size: #{font_px}px;" unless block.image_block? %>">
  <% if block.image_block? %>
    <% if block.main_image.attached? %>
      <%= image_tag block.main_image, class: "cover-block-image" %>
    <% else %>
      <div class="cover-block-image-placeholder">Image</div>
    <% end %>
  <% else %>
    <div class="cover-block-text"><%= block.content %></div>
  <% end %>
</div>
