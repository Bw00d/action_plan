<div>
  <%= render 'new_block_form', block: block, insertion_type: 'above' %>

  <!-- Style control panel -->
  <div class="style-controls">
    <div class="h1-text"><h1>H1</h1></div>
    <div class="h2-text"><h2>H2</h2></div>
    <div class="h3-text"><h3>H3</h3></div>
    <div class="h4-text"><h4>H4</h4></div>
    <div class="normal-text">Norm</div>
    <div class="semi-text semi-bold">Semi</div>
    <div class="bold-text bold">Bold</div>
    <div class="italic-text"><em>Italic</em></div>
    <!-- <div class="add-image-block"><%#= fa_icon('image') %></div> -->
    <div class="add-image-block"><%= image_tag('white-image.png') %></div>

    <!-- <div class="delete-block"><%#= fa_icon('trash') %></div> --> 
    <div class="delete-block"><%= link_to image_tag('white-trash.png'), block,  method: :delete, data: { confirm: 'Are you sure?' } %></div>
  </div>
  <!-- End style control panel -->

  <!-- Now block type panel -->
  <div id="<%= dom_id(block) %>" class="block gray-border <%= block.font_size %> <%= block.font_family %> <%= block.font_weight %> <%= block.text_style %> <%= block.bottom_padding %>" >

    <!-- This style an image block (including split blocks) -->
    <% if block.image_block? %> 
      <!-- Debug: image_width = <%= block.image_width.inspect %> -->
      <div class="resizable">
        <div class="resizers <%= 'no-image' unless block.main_image.attached? %>" style="width: <%= block.image_width.presence || (block.split_block? ? '45%' : '65%') %>;<%= " transform: translateX(#{block.image_position_x});" if block.split_block? && block.image_position_x.present? %>">
          <div class='resizer top-left'></div>
          <div class='resizer top-right'></div>
          <div class='resizer bottom-left'></div>
          <div class='resizer bottom-right'></div>

          <% if block.main_image.attached? %>
           <%= image_tag block.main_image, class: "cover-image" %>
          <% end %>
          <% if block.split_block? %>
            <img id="small-temp-image"></img>
          <% else %>
            <img id="temp-image"></img>
          <% end %>
        </div>
      </div>
      <div class="image-form">
        <%= form_for block, html: {class: "edit-image-block"}  do |f| %>
          <%= f.file_field :main_image, class: 'small-button' %>
          <%= f.hidden_field :bottom_padding %>
          <%= f.submit "Upload" %>
          <%= button_tag "Cancel", type: "button", class: "cancel-image-upload" %>
        <% end %>
      </div>
      <!-- Hidden form for saving dimensions -->
      <%= form_for block, html: {class: "edit_block", style: "display: none;"}, remote: true do |f| %>
        <%= f.hidden_field :image_width %>
        <%= f.hidden_field :image_position_x %>
      <% end %>
    <% end %>
    <!-- End style a split block -->
    
    <% unless block.image_block? || block.blank? %>           
      <!-- Block form -->
      <%= form_for block, class: "block-form", remote: true do |f| %>
        <%= f.hidden_field :id %>
        <%= f.hidden_field :bottom_padding %>
        <%= f.hidden_field :font_size %>
        <%= f.hidden_field :font_family %>
        <%= f.hidden_field :number %>
        <%= f.hidden_field :font_weight %>
        <%= f.hidden_field :text_align %>
        <%= f.hidden_field :text_style %>
        <%= f.hidden_field :image_block %>
        <%= f.hidden_field :blank %>
        <%= f.hidden_field :image_width %>
        <%= f.submit "Save", class: "save-block-button" %>
      <% end %> 
      <%= best_in_place block, :content, :as => :input, class: 'bock-content' %>
    <% end %>
    
    <div style="height: <%= block.bottom_padding %>" class="bottom-padding"><div class="resize-padding"></div></div>
  </div> 
  <%= render 'new_block_form', block: block, insertion_type: 'below' %>
</div>