<%= content_for :title, "Imported Requests" %>

<% if notice.present? %><p id="notice"><%= notice %></p><% end %>

<div class="incident-name">
  <h1><%= link_to @incident.display_incident_name, @incident %></h1>
</div>

<div class="requests-index">
  <div class="requests-header">
    <h2>Imported Requests <span class="muted">(<%= @requests.size %> total)</span></h2>
    <div class="requests-actions">
      <%= link_to "Back to Resources", incident_resources_path(@incident), class: "btn btn-secondary" %>
      <%= link_to "Import another dump", new_incident_dump_import_path(@incident), class: "btn btn-primary" %>
    </div>
  </div>

  <% if @requests.empty? %>
    <p>No requests have been imported for this incident yet.</p>
  <% else %>
    <div class="requests-summary">
      <% @grouped.each do |catalog, rows| %>
        <span class="catalog-pill"><strong><%= catalog %>:</strong> <%= rows.size %></span>
      <% end %>
    </div>

    <% @grouped.each do |catalog, rows| %>
      <h3 class="catalog-heading"><%= catalog %> (<%= rows.size %>)</h3>
      <table class="requests-table">
        <thead>
          <tr>
            <th>Req #</th>
            <th>Category</th>
            <th>Resource Name</th>
            <th>Person</th>
            <th>Employment</th>
            <th>Filled Item</th>
            <th>Assignment</th>
            <th>Provider</th>
            <th>Mob ETD</th>
            <th>Vendor</th>
          </tr>
        </thead>
        <tbody>
          <% rows.each do |r| %>
            <tr>
              <td><%= [r.req_number_prefix, r.req_number].compact.join("-") %></td>
              <td><%= r.req_category_name %></td>
              <td><%= r.res_name %></td>
              <td><%= r.person? ? r.full_name : "—" %></td>
              <td><%= r.employment_class %></td>
              <td><%= [r.filled_catalog_item_code, r.filled_catalog_item_name].compact.join(" — ") %></td>
              <td><%= r.assignment_name %></td>
              <td><%= [r.res_prov_agency_abbrev, r.res_prov_unit_code].compact.join(" / ") %></td>
              <td><%= r.mob_etd&.strftime("%Y-%m-%d %H:%M") %></td>
              <td><%= r.vendor_owned_flag ? r.vendor_name : "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  <% end %>
</div>
