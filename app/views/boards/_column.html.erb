<div class="board-column" id="<%= column_id %>" data-org-unit-id="<%= org_unit_id %>">
  <div class="board-column-header">
    <% if subtitle %>
      <div class="board-column-subtitle"><%= subtitle %></div>
    <% end %>
    <div class="board-column-title-row">
      <div class="board-column-title"><%= title %></div>
      <% if local_assigns[:unit] && OrgUnitsController::DELETABLE_KINDS.include?(unit.kind) %>
        <%= button_to '×',
                      incident_org_unit_path(@incident, unit),
                      method: :delete,
                      class: 'board-column-delete',
                      form: { class: 'board-column-delete-form' },
                      data: { confirm: "Delete \"#{unit.name}\"? Any child branches/divisions/groups are deleted too. Resources on these units move to Unassigned." },
                      title: 'Delete this unit' %>
      <% end %>
    </div>
  </div>

  <ul class="board-cards">
    <% resources.each do |resource| %>
      <%= render 'card', resource: resource %>
    <% end %>
  </ul>

  <% if local_assigns[:unit] && unit.can_have_children? %>
    <%= render 'add_child_form', incident: @incident, unit: unit %>
  <% end %>
</div>
